      "command": "node",
      "args": ["D:/UGit/extension-tools/cocosmcp/mcp/index.mjs"],
      "cwd": "D:/UGit/proj-l-client-candy",
      "env": {
        "COCOSMCP_PLUGINS": "candystorm-ir,genbot",
        "COCOSMCP_IR_ROOT": "D:/svn/new_game/糖果风暴客户端资源/export/candystorm_ir"
      }
    },
    "cocosmcp-admin": {
      "comment": "Agent recipe + 插件管理",
